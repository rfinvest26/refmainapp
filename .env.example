# Base URL of the deployed `ref-miniapp` Supabase Edge Function, e.g.:
# https://<project-ref>.supabase.co/functions/v1/ref-miniapp
VITE_API_BASE_URL=

# Username of the refbot (without @) — used to build "open in bot" deep links.
VITE_REF_BOT_USERNAME=voidtrafficwork_bot

# Username of the MAIN bot (without @) — used to build referral/campaign links
# (these always point into the main bot, not the refbot).
VITE_BOT_USERNAME=mainvoid_bot
